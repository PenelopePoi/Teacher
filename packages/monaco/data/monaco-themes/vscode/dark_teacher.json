    "list.focusBackground": "#E8A94825",
    "list.highlightForeground": "#E8A948",
    "list.dropBackground": "#E8A94820",

    "tree.indentGuidesStroke": "#23272E40",

    "input.background": "#1A1D22",
    "input.foreground": "#F2F4F7",
    "input.border": "#23272E",
