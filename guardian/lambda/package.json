{
    "name": "@guardian/lambda",
    "version": "0.1.0",
    "description": "AWS Lambda handler wrapping @guardian/core with DynamoDB WAL and KMS signer.",
    "private": true,
    "main": "dist/handler.js",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "bundle": "node esbuild.config.mjs",
        "test": "jest",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@aws-sdk/client-dynamodb": "3.623.0",
        "@aws-sdk/client-kms": "3.623.0",
        "@aws-sdk/lib-dynamodb": "3.623.0",
        "@guardian/core": "file:../core"
    },
    "devDependencies": {
        "@types/aws-lambda": "8.10.145",
        "@types/jest": "29.5.12",
        "@types/node": "20.11.24",
        "esbuild": "0.23.1",
        "jest": "29.7.0",
        "ts-jest": "29.1.2",
        "typescript": "5.4.5"
    },
    "engines": {
        "node": ">=20"
    }
}
